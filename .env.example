# OpenClaw gateway integration
OPENCLAW_GATEWAY_BASE_URL=http://127.0.0.1:18789
OPENCLAW_HOOKS_TOKEN=replace_me

# Sidecar runtime
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=9600
OPENCLAW_EXECUTING_TIMEOUT_SEC=3600
OPENCLAW_REVIEWING_TIMEOUT_SEC=1800
OPENCLAW_BLOCKED_ALERT_AFTER_SEC=600
OPENCLAW_DEFAULT_RUNTIME_MODE=legacy_single
SIDECAR_DB_PATH=./data/sidecar.db
SIDECAR_LOG_LEVEL=INFO
