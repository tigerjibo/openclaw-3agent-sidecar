# OpenClaw gateway integration
OPENCLAW_GATEWAY_BASE_URL=http://127.0.0.1:18789
OPENCLAW_HOOKS_TOKEN=replace_me
OPENCLAW_PUBLIC_BASE_URL=
OPENCLAW_HOOK_REGISTRATION_RETRY_SEC=300
OPENCLAW_HOOK_REGISTRATION_FAILURE_ALERT_AFTER=3
# Used by the lightweight gateway client skeleton, authenticated hook calls,
# hook registration, and hook status queries.
# Set OPENCLAW_PUBLIC_BASE_URL when the upstream gateway should automatically
# register the sidecar's externally reachable hook callbacks.
# OPENCLAW_HOOK_REGISTRATION_RETRY_SEC limits how often automatic re-registration
# should retry after a failed or rejected attempt.
# OPENCLAW_HOOK_REGISTRATION_FAILURE_ALERT_AFTER degrades service health after
# repeated hook registration failures exceed the configured threshold.

# Sidecar runtime
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=9600
OPENCLAW_EXECUTING_TIMEOUT_SEC=3600
OPENCLAW_REVIEWING_TIMEOUT_SEC=1800
OPENCLAW_BLOCKED_ALERT_AFTER_SEC=600
OPENCLAW_DEFAULT_RUNTIME_MODE=legacy_single
OPENCLAW_DB_PATH=./data/sidecar.db
OPENCLAW_RUNTIME_INVOKE_URL=
OPENCLAW_INTEGRATION_PROBE_TTL_SEC=30
OPENCLAW_LOG_LEVEL=INFO

# When OPENCLAW_RUNTIME_INVOKE_URL is enabled for real upstream delivery,
# keep OPENCLAW_HOOKS_TOKEN and OPENCLAW_PUBLIC_BASE_URL configured too so the
# sidecar can advertise an authenticated result callback contract back to the
# OpenClaw runtime. Without those callback settings, ops payloads will surface
# the runtime wiring as only partially configured.

# Example authenticated sidecar ingress hook:
# POST /hooks/openclaw/ingress with header X-OpenClaw-Hooks-Token: $OPENCLAW_HOOKS_TOKEN
# Example authenticated sidecar result hook:
# POST /hooks/openclaw/result with header X-OpenClaw-Hooks-Token: $OPENCLAW_HOOKS_TOKEN

# Legacy aliases still supported for compatibility:
# SIDECAR_DB_PATH=./data/sidecar.db
# SIDECAR_LOG_LEVEL=INFO
