# AWS staging candidate configuration for openclaw-3agent-sidecar
#
# Source of current upstream clues:
# - M:\code\openclaw\SYNC_RUNBOOK.md
# - live AWS check on 2026-03-14
# - SSH host works: ubuntu@13.51.172.206
# - Nginx public domain: https://ec2-13-60-187-160.eu-north-1.compute.amazonaws.com
# - current local 9600 is occupied by a legacy three_agent_system process
# - current gateway POST probes for /invoke and /runtime/invoke return 404
#
# Important: this file is a starting template, not a claim that every endpoint
# below has already been verified in the live environment.

# -----------------------------
# Sidecar local service settings
# -----------------------------
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=9610
OPENCLAW_DB_PATH=./data/sidecar-staging.db
OPENCLAW_EXECUTING_TIMEOUT_SEC=3600
OPENCLAW_REVIEWING_TIMEOUT_SEC=1800
OPENCLAW_BLOCKED_ALERT_AFTER_SEC=600
OPENCLAW_DEFAULT_RUNTIME_MODE=legacy_single
OPENCLAW_INTEGRATION_PROBE_TTL_SEC=30
OPENCLAW_LOG_LEVEL=INFO

# Bind locally and let Nginx publish /sidecar/ publicly. This avoids exposing
# the new sidecar directly while the legacy process is still present on the host.

# -----------------------------------
# OpenClaw upstream gateway integration
# -----------------------------------
# Candidate public gateway base URL confirmed during the live AWS check.
OPENCLAW_GATEWAY_BASE_URL=https://ec2-13-60-187-160.eu-north-1.compute.amazonaws.com

# Must be shared with the upstream gateway/runtime so they can call the sidecar
# hooks securely.
OPENCLAW_HOOKS_TOKEN=replace_with_real_shared_hooks_token

# Externally reachable sidecar base URL.
# Recommended first rollout shape on the current AWS host:
# expose the new sidecar through Nginx under /sidecar/ and keep it separate
# from the already-running legacy process on 127.0.0.1:9600.
OPENCLAW_PUBLIC_BASE_URL=https://ec2-13-60-187-160.eu-north-1.compute.amazonaws.com/sidecar

OPENCLAW_HOOK_REGISTRATION_RETRY_SEC=300
OPENCLAW_HOOK_REGISTRATION_FAILURE_ALERT_AFTER=3

# ------------------------
# Runtime invoke integration
# ------------------------
# Live AWS verification showed that current POST probes to the candidate gateway
# routes `/invoke`, `/runtime/invoke`, and `/api/runtime/invoke` return 404.
# Therefore the honest initial staging configuration is to leave this unset
# until a real upstream HTTP submit endpoint exists.
OPENCLAW_RUNTIME_INVOKE_URL=

# Keep these only as future candidate shapes after upstream support exists:
# OPENCLAW_RUNTIME_INVOKE_URL=https://ec2-13-60-187-160.eu-north-1.compute.amazonaws.com/invoke
# OPENCLAW_RUNTIME_INVOKE_URL=https://ec2-13-60-187-160.eu-north-1.compute.amazonaws.com/runtime/invoke
# OPENCLAW_RUNTIME_INVOKE_URL=https://ec2-13-60-187-160.eu-north-1.compute.amazonaws.com/api/runtime/invoke

# When OPENCLAW_RUNTIME_INVOKE_URL is enabled for real upstream delivery,
# keep OPENCLAW_HOOKS_TOKEN and OPENCLAW_PUBLIC_BASE_URL configured too so the
# sidecar can advertise an authenticated result callback contract back to the
# OpenClaw runtime.

# Example authenticated sidecar ingress hook:
# POST /hooks/openclaw/ingress
# Header: X-OpenClaw-Hooks-Token: $OPENCLAW_HOOKS_TOKEN

# Example authenticated sidecar result hook:
# POST /hooks/openclaw/result
# Header: X-OpenClaw-Hooks-Token: $OPENCLAW_HOOKS_TOKEN