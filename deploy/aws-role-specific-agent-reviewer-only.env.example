# AWS staging reviewer-only role-routing baseline for openclaw-3agent-sidecar
#
# Validated on 2026-03-15 on the current AWS staging host.
#
# Use this as a focused baseline for the already-proven first rollout shape:
# - coordinator falls back to `main`
# - executor falls back to `main`
# - reviewer is routed to `sysarch`
#
# This file is intentionally a minimal, copyable baseline for the validated
# role-routing shape. Merge it into the real service `.env` that already has
# the host/port/db/log settings you want to keep.
#
# Companion docs:
# - deploy/aws-role-specific-agent-staging-rollout-checklist.md
# - docs/plans/2026-03-15-role-specific-agent-staging-validation.md

# -----------------------------------
# OpenClaw upstream gateway integration
# -----------------------------------
# Keep the real public callback base and shared hooks token configured when you
# expect a real submit/result loop.
OPENCLAW_PUBLIC_BASE_URL=https://ec2-13-60-187-160.eu-north-1.compute.amazonaws.com/sidecar
OPENCLAW_HOOKS_TOKEN=replace_with_real_shared_hooks_token

# ------------------------
# Runtime invoke integration
# ------------------------
# Current validated bridge shape on AWS staging.
OPENCLAW_RUNTIME_INVOKE_URL=openclaw-cli://main

# --------------------------
# Role-specific CLI routing
# --------------------------
# Reviewer-only first-pass rollout:
# - leave coordinator / executor blank so they safely fall back to `main`
# - pin reviewer to the independently validated `sysarch` agent
OPENCLAW_COORDINATOR_AGENT_ID=
OPENCLAW_EXECUTOR_AGENT_ID=
OPENCLAW_REVIEWER_AGENT_ID=sysarch

# Notes:
# - `main` and `sysarch` were validated on the host during staging checks.
# - `work` returned `Unknown agent id` and should not be used until re-confirmed.
# - If `python -m sidecar.remote_validate` is run on the same host while the
#   formal service is already bound to 9600, temporarily override:
#     OPENCLAW_PORT=0
#     OPENCLAW_DB_PATH=/tmp/openclaw-sidecar-remote-validate.sqlite3
